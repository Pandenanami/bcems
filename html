        <!-- SECCIÓN: PROCEDIMIENTOS -->
        <section id="procedimientos" class="section">
            <h2 class="section-title"><i class="fas fa-procedures"></i> PROCEDIMIENTOS MÉDICOS</h2>
            <p class="section-desc">Guías paso a paso de procedimientos avanzados de vida. Solo personal autorizado.</p>

            <div class="procedures-accordion">
                <!-- Procedimiento 1 -->
                <div class="procedure-item">
                    <button class="procedure-toggle" onclick="toggleProcedure(this)">
                        <span><i class="fas fa-syringe"></i> Acceso Intraóseo (IO)</span>
                        <i class="fas fa-chevron-down"></i>
                    </button>
                    <div class="procedure-content">
                        <div class="procedure-steps">
                            <h4>Indicaciones:</h4>
                            <ul>
                                <li>Acceso IV imposible o fallido tras 2 intentos</li>
                                <li>Paro cardíaco</li>
                                <li>Shock hemorrágico</li>
                                <li>Estado de mal convulsivo</li>
                            </ul>
                            <h4>Sitios de punción:</h4>
                            <ul>
                                <li><strong>Proximal tibia:</strong> 2cm medial y distal a la tuberosidad tibial</li>
                                <li><strong>Húmero proximal:</strong> Cabeza humeral, lateral al surco intertubercular</li>
                                <li><strong>Esternón:</strong> Solo en adultos con dispositivo específico</li>
                            </ul>
                            <h4>Pasos:</h4>
                            <ol>
                                <li>Identificar sitio anatómico</li>
                                <li>Preparar área con clorhexidina</li>
                                <li>Estabilizar hueso (mano no dominante)</li>
                                <li>Insertar aguja perpendicular al hueso</li>
                                <li>Retirar stylet, aspirar para confirmar</li>
                                <li>Conectar línea de infusión</li>
                                <li>Fijar con vendaje</li>
                            </ol>
                            <div class="procedure-alert">
                                <i class="fas fa-skull-crossbones"></i>
                                <strong>Contraindicaciones:</strong> Fractura en el hueso, infección local, prótesis articular, osteogénesis imperfecta.
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Procedimiento 2 -->
                <div class="procedure-item">
                    <button class="procedure-toggle" onclick="toggleProcedure(this)">
                        <span><i class="fas fa-lungs"></i> Intubación Orotraqueal</span>
                        <i class="fas fa-chevron-down"></i>
                    </button>
                    <div class="procedure-content">
                        <div class="procedure-steps">
                            <h4>Indicaciones:</h4>
                            <ul>
                                <li>Fallo de ventilación con BVM</li>
                                <li>Protección de vía aérea (GCS < 8)</li>
                                <li>Paro cardíaco (post-ROSC)</li>
                                <li>Insuficiencia respiratoria severa</li>
                            </ul>
                            <h4>Tamaños de tubo:</h4>
                            <ul>
                                <li>Adulto masculino: 8.0 - 8.5 mm</li>
                                <li>Adulto femenino: 7.5 - 8.0 mm</li>
                                <li>Pediátrico: (Edad/4) + 4 (fórmula de Broselow)</li>
                            </ul>
                            <h4>Pasos (RSI):</h4>
                            <ol>
                                <li>Preoxigenación 100% O₂ por 3 min</li>
                                <li>Preparar equipo (laringoscopio, tubo, jeringa, fijador)</li>
                                <li>Posición sniffing (almohada bajo occipital)</li>
                                <li>Sedación + relajante muscular (Ketamina + Rocuronio)</li>
                                <li>Laringoscopia con laringoscopio curvo (Mac #3-4)</li>
                                <li>Visualizar comisuras y cartílagos aritenoides</li>
                                <li>Introducir tubo hasta la marca de los dientes</li>
                                <li>Inflar balón (5-10ml aire)</li>
                                <li>Confirmar con capnografía (waveform EtCO2)</li>
                                <li>Fijar tubo y auscultar epigastrio y campos pulmonares</li>
                            </ol>
                            <div class="procedure-alert">
                                <i class="fas fa-exclamation-triangle"></i>
                                <strong>Confirmación:</strong> Siempre confirmar con capnografía. La auscultación sola NO es suficiente.
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Procedimiento 3 -->
                <div class="procedure-item">
                    <button class="procedure-toggle" onclick="toggleProcedure(this)">
                        <span><i class="fas fa-heartbeat"></i> Desfibrilación</span>
                        <i class="fas fa-chevron-down"></i>
                    </button>
                    <div class="procedure-content">
                        <div class="procedure-steps">
                            <h4>Indicaciones:</h4>
                            <ul>
                                <li>Fibrilación ventricular (FV)</li>
                                <li>Taquicardia ventricular sin pulso (TVSP)</li>
                            </ul>
                            <h4>Energía recomendada:</h4>
                            <ul>
                                <li>Adulto: 200J (bifásico) / 360J (monofásico)</li>
                                <li>Pediátrico: 2 J/kg (1° dosis), 4 J/kg (dosis subsecuentes)</li>
                            </ul>
                            <h4>Pasos:</h4>
                            <ol>
                                <li>Confirmar ritmo desfibrilable en monitor</li>
                                <li>Comando "¡CARGANDO! ¡Todos alejados!"</li>
                                <li>Cargar DESA al joule indicado</li>
                                <li>Verificar que NADIE toca al paciente</li>
                                <li>Aplicar paletas/parchos firmemente</li>
                                <li>Comando "¡DESCARGA!" y presionar ambos botones</li>
                                <li>Reanudar compresiones inmediatamente</li>
                                <li>Evaluar ritmo tras 2 min de RCP</li>
                            </ol>
                            <div class="procedure-alert">
                                <i class="fas fa-bolt"></i>
                                <strong>Seguridad:</strong> Asegurar que el paciente NO está en superficie metálica ni en contacto con líquidos conductores.
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Procedimiento 4 -->
                <div class="procedure-item">
                    <button class="procedure-toggle" onclick="toggleProcedure(this)">
                        <span><i class="fas fa-tint"></i> Control de Hemorragias</span>
                        <i class="fas fa-chevron-down"></i>
                    </button>
                    <div class="procedure-content">
                        <div class="procedure-steps">
                            <h4>Jerarquía de control:</h4>
                            <ol>
                                <li><strong>Presión directa</strong> - Mano sobre herida con gasas estériles</li>
                                <li><strong>Agentes hemostáticos</strong> - Celox, QuickClot sobre herida</li>
                                <li><strong>Vendaje compresivo</strong> - Vendaje elástico firme</li>
                                <li><strong>Torniquete</strong> - SOLO extremidades, 5-7cm proximal a herida</li>
                                <li><strong>Empaquetamiento de herida</strong> - Gasas hemostáticas en heridas de cuello/axila/ingle</li>
                            </ol>
                            <h4>Uso de torniquete:</h4>
                            <ul>
                                <li>Aplicar lo más proximal posible</li>
                                <li>Apretar hasta cesar sangrado y pulso distal</li>
                                <li>Anotar hora de aplicación (visible)</li>
                                <li>NO aflojar en campo</li>
                                <li>Notificar al hospital receptor</li>
                            </ul>
                            <div class="procedure-alert critical">
                                <i class="fas fa-clock"></i>
                                <strong>Tiempo crítico:</strong> El torniquete puede dejarse hasta 2 horas sin daño neurológico permanente. Más de 6 horas = riesgo de amputación.
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Procedimiento 5 -->
                <div class="procedure-item">
                    <button class="procedure-toggle" onclick="toggleProcedure(this)">
                        <span><i class="fas fa-bone"></i> Inmovilización Espinal</span>
                        <i class="fas fa-chevron-down"></i>
                    </button>
                    <div class="procedure-content">
                        <div class="procedure-steps">
                            <h4>Criterios de inmovilización:</h4>
                            <ul>
                                <li>Trauma con mecanismo significativo</li>
                                <li>Dolor cervical o dorsal</li>
                                <li>Déficit neurológico (entumecimiento, debilidad)</li>
                                <li>Alteración de conciencia</li>
                                <li>Intoxicación (alcohol/drogas)</li>
                                <li>Distracción dolorosa (fractura de fémur)</li>
                            </ul>
                            <h4>Técnica:</h4>
                            <ol>
                                <li>Manual in-line stabilization (MILS) desde atrás</li>
                                <li>Aplicar collar cervical apropiado (talla correcta)</li>
                                <li>Log-roll de 4 personas (jefe, pecho, caderas, piernas)</li>
                                <li>Inspeccionar dorso durante log-roll</li>
                                <li>Colocar tabla espinal con almohadillas</li>
                                <li>Asegurar con cinchas (pecho, caderas, piernas)</li>
                                <li>Fijar cabeza con bloques o cinta</li>
                            </ol>
                            <div class="procedure-alert">
                                <i class="fas fa-exclamation-circle"></i>
                                <strong>Importante:</strong> No usar collar cervical en pacientes con trauma penetrante de cuello (riesgo de aumentar presión intracraneal).
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Procedimiento 6 -->
                <div class="procedure-item">
                    <button class="procedure-toggle" onclick="toggleProcedure(this)">
                        <span><i class="fas fa-thermometer-half"></i> Manejo de Hipotermia</span>
                        <i class="fas fa-chevron-down"></i>
                    </button>
                    <div class="procedure-content">
                        <div class="procedure-steps">
                            <h4>Clasificación:</h4>
                            <ul>
                                <li><strong>Leve (32-35°C):</strong> Escalofríos, taquicardia, confusión</li>
                                <li><strong>Moderada (28-32°C):</strong> Bradicardia, letargo, arritmias</li>
                                <li><strong>Severa (<28°C):</strong> Coma, fibrilación ventricular, "muerte aparente"</li>
                            </ul>
                            <h4>Manejo:</h4>
                            <ol>
                                <li>Manejo suave - No manipular bruscamente (riesgo de FV)</li>
                                <li>Secar y cubrir con mantas térmicas</li>
                                <li>Retirar ropa mojada</li>
                                <li>Calentar el torso primero (no extremidades)</li>
                                <li>Fluidos IV calentados (40°C)</li>
                                <li>Oxígeno calentado y humidificado</li>
                                <li>Evitar café/alcohol (vasodilatación periférica)</li>
                            </ol>
                            <div class="procedure-alert">
                                <i class="fas fa-snowflake"></i>
                                <strong>Regla:</strong> "No está muerto hasta que esté caliente y muerto". Continuar RCP hasta temperatura central > 32°C.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

